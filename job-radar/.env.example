# Environment variables for Job Radar
# Copy this file to .env and fill in your values

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Gmail API (optional, credentials.json is primary)
# GMAIL_SENDER_EMAIL=your_email@gmail.com

# Database
DATABASE_PATH=data/job_radar.db

# Logging
LOG_LEVEL=INFO

# Google Sheets
GOOGLE_SHEET_ID=your_spreadsheet_id_here
